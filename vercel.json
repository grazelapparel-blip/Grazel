{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "env": [
    "MONGODB_URI",
    "NODE_ENV",
    "PORT"
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    },
    "server/**/*.js": {
      "runtime": "nodejs20.x"
    }
  }
}
