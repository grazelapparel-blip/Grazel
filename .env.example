# MongoDB Configuration
# Replace with your MongoDB Atlas connection string or local MongoDB URI
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.your-id.mongodb.net/grazel?retryWrites=true&w=majority

# Alternative for local MongoDB development:
# MONGODB_URI=mongodb://localhost:27017/grazel

# JWT Secret Key
# Use a strong, random string for production. Can be generated with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# Server Port
PORT=5000

# Frontend Dev Port (for reference)
VITE_PORT=8080
